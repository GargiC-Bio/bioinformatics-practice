# (1) how many records are in the file:
import os

# This part checks if the file exists before trying to open it
file_name = 'dna.example (1).fasta'

if os.path.exists(file_name):
    count = 0
    with open(file_name, 'r') as f:
        for line in f:
            if line.startswith('>'):
                count += 1
    print(f"The number of records in the file is: {count}")
else:
    print(f"Error: The file '{file_name}' was not found in this folder.")
    print("Files currently in this folder are:", os.listdir('.'))



## (2) What are the lengths of the sequences in the file? What is the longest sequence and what is the shortest sequence? Is there more than one longest or shortest sequence? What are their identifiers? 
file_name = 'dna.example (1).fasta'

try:
    sequences = {}
    with open(file_name, 'r') as f:
        current_id = None
        current_seq = []
        
        for line in f:
            line = line.strip()
            if not line: continue
            
            if line.startswith(">"):
                # If we were already building a sequence, save it before starting new one
                if current_id:
                    sequences[current_id] = "".join(current_seq)
                
                # Get the name (everything after '>')
                current_id = line[1:].split()[0]
                current_seq = []
            else:
                # This is a sequence line, add it to the list
                current_seq.append(line)
        
        # Save the very last sequence in the file
        if current_id:
            sequences[current_id] = "".join(current_seq)

    # --- CALCULATIONS ---
    lengths = {id: len(seq) for id, seq in sequences.items()}
    
    max_len = max(lengths.values())
    min_len = min(lengths.values())
    
    # Find IDs for all sequences that match the max/min lengths
    longest_ids = [id for id, length in lengths.items() if length == max_len]
    shortest_ids = [id for id, length in lengths.items() if length == min_len]

    print(f"Longest sequence length: {max_len}")
    print(f"Shortest sequence length: {min_len}")
    print(f"Identifier(s) of longest: {longest_ids}")
    print(f"Identifier(s) of shortest: {shortest_ids}")

except FileNotFoundError:
    print("File not found. Make sure the data file is in the same folder!")



## (3)Given an input reading frame on the forward strand (1, 2, or 3) your program should be able to identify all ORFs present in each sequence of the FASTA file, and answer the following questions: what is the length of the longest ORF in the file? What is the identifier of the sequence containing the longest ORF? For a given sequence identifier, what is the longest ORF contained in the sequence represented by that identifier? What is the starting position of the longest ORF in the sequence that contains it? 
file_name = 'dna.example (1).fasta'

def find_longest_orf(sequence, frame):
    start_codon = "ATG"
    stop_codons = ["TAA", "TAG", "TGA"]
    longest_orf = 0
    start_pos = -1
    
    # Adjust for reading frame (1, 2, or 3 maps to index 0, 1, or 2)
    for i in range(frame - 1, len(sequence), 3):
        codon = sequence[i:i+3]
        if codon == start_codon and start_pos == -1:
            start_pos = i
        elif codon in stop_codons and start_pos != -1:
            orf_len = (i + 3) - start_pos
            if orf_len > longest_orf:
                longest_orf = orf_len
            start_pos = -1 # Reset to find the next one
    return longest_orf


## (4)   A repeat is a substring of a DNA sequence that occurs in multiple copies (more than one) somewhere in the sequence. Although repeats can occur on both the forward and reverse strands of the DNA sequence, we will only consider repeats on the forward strand here. Also we will allow repeats to overlap themselves. For example, the sequence ACACA contains two copies of the sequence ACA - once at position 1 (index 0 in Python), and once at position 3. Given a length n, your program should be able to identify all repeats of length n in all sequences in the FASTA file. Your program should also determine how many times each repeat occurs in the file, and which is the most frequent repeat of a given length.
from collections import Counter

file_name = 'dna.example (1).fasta'
n = 6  # Change this to the length 'n' requested in your question

try:
    sequences = {}
    with open(file_name, 'r') as f:
        current_id = None
        current_seq = []
        for line in f:
            line = line.strip()
            if line.startswith(">"):
                if current_id: sequences[current_id] = "".join(current_seq)
                current_id = line[1:].split()[0]
                current_seq = []
            else:
                current_seq.append(line)
        if current_id: sequences[current_id] = "".join(current_seq)

    # Dictionary to count repeats across all sequences
    all_repeats = Counter()

    for dna in sequences.values():
        # Sliding window to find every substring of length n
        for i in range(len(dna) - n + 1):
            substring = dna[i:i+n]
            all_repeats[substring] += 1

    # Find the most frequent repeat(s)
    if all_repeats:
        most_common = all_repeats.most_common()
        max_freq = most_common[0][1]
        
        # There might be a tie for the most frequent
        winners = [rep for rep, count in most_common if count == max_freq]

        print(f"--- Question 4 Results (n={n}) ---")
        print(f"Most frequent repeat(s): {winners}")
        print(f"Occurrences: {max_freq}")
        print(f"Number of distinct repeats of length {n} found: {len(all_repeats)}")
    else:
        print("No repeats found. Is the sequence too short?")

except FileNotFoundError:
    print("Double-check that dna.example.fasta is in your 'coding' folder!")
