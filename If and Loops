dna=input('Enter DNA sequence:')

if 'n' in dna or 'N' in dna:
    Nnbases=dna.count('n')+dna.count('N')
    print("dna sequence has %d undefined bases " % Nnbases)
elif 'n' in dna and 'N' in dna:
    vbases=dna.count('n')+dna.count('N')
    print("dna sequence has %d undefined bases " % vbases)
else:
    print('dna sequence has no undefined bases')

# while loop
dna=input('Enter DNA sequence:')
pos=dna.find('gt',0) # position of donor splice site
while pos>-1:
    print("Donor splice site candidate at position %d"%pos)
    pos=dna.find('gt',pos+1)

